{
  // Nombre visible del entorno en VS Code y GitHub Codespaces.
  "name": "Codespace Ubuntu 24.04 con Docker",

  // Indica que la imagen se construirá desde el Dockerfile del repositorio.
  "build": {
    // Dockerfile ubicado junto a este archivo dentro de .devcontainer.
    "dockerfile": "Dockerfile",

    // Usa la raíz del repositorio como contexto de construcción de Docker.
    "context": ".."
  },

  // Instala Docker y su daemon interno mediante la Feature oficial.
  "features": {
    // La opción moby utiliza la distribución de Docker mantenida para Linux.
    "ghcr.io/devcontainers/features/docker-in-docker:4": {
      "version": "latest",
      "moby": true,

      // Permite que el usuario vscode ejecute docker sin cambiar a root.
      "enableNonRootDocker": true
    }
  },

  // Personalizaciones que VS Code aplicará dentro del contenedor.
  "customizations": {
    // Configuración específica del editor VS Code.
    "vscode": {
      // Extensiones instaladas automáticamente en el Codespace.
      "extensions": [
        // Muestra iconos para tipos de archivo y carpetas.
        "vscode-icons-team.vscode-icons"
      ],

      // Preferencias iniciales del editor.
      "settings": {
        // Activa el tema de iconos instalado anteriormente.
        "workbench.iconTheme": "vscode-icons",

        // Usa Bash como terminal predeterminada.
        "terminal.integrated.defaultProfile.linux": "bash",

        // Usa saltos de línea LF, habituales en Linux.
        "files.eol": "\n"
      }
    }
  },

  // Inicia el daemon de Tailscale cada vez que arranca el contenedor.
  "postStartCommand": "bash .devcontainer/start-tailscaled.sh",

  // Define el usuario no-root que utilizarán VS Code, las terminales y las tareas.
  "remoteUser": "vscode"
}
