{
  "name": "Codespace básico con Ubuntu",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscode-icons-team.vscode-icons"
      ],
      "settings": {
        "workbench.iconTheme": "vscode-icons",
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  },
  "remoteUser": "vscode"
}
